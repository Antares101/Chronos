{
  "name": "chronos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "typecheck": "astro check",
    "lint": "eslint . --ext .js,.ts,.astro",
    "format": "prettier --write --ignore-unknown \"*.{js,ts,cjs,json}\" \"src/**/*.{astro,ts,tsx}\" \".env.example\"",
    "format:check": "prettier --check --ignore-unknown \"*.{js,ts,cjs,json}\" \"src/**/*.{astro,ts,tsx}\" \".env.example\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "astro": "^7.0.3",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.9.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
