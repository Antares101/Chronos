---
import ChronosAppShell from '../../components/app/ChronosAppShell.astro';
import DailyReviewCards from '../../components/review/DailyReviewCards';
import ConclusionPanel from '../../components/review/ConclusionPanel';
import type { ChronosAuthLocals } from '../../server/auth';
import { loadChronosReviewState } from '../../server/app/chronos-app';
import {
  chronosAppRoutes,
  resolveChronosActionRouteContext,
} from '../../server/app/route-contract';

const routePath = chronosAppRoutes.review;

const routeContext = await resolveChronosActionRouteContext({
  user: (Astro.locals as ChronosAuthLocals).user,
  request: Astro.request,
  currentUrl: Astro.url,
  routePath,
});

if (routeContext.kind === 'redirect') {
  return Astro.redirect(routeContext.location, routeContext.status);
}

const { actionError, email, repositories, statusMessage, userId } = routeContext;
const appState = await loadChronosReviewState(repositories, userId);
---

<ChronosAppShell
  title="Chronos Review"
  eyebrow="Review"
  heading="Close a block"
  summary="Review one active block at a time, mark what finished, and note the adjustment for tomorrow."
  email={email}
  currentPath={routePath}
  actionError={actionError}
  statusMessage={statusMessage}
>
  <div class="app-route app-route--review">
    <section class="actions" aria-labelledby="review-actions-title">
      <div class="actions__header">
        <p class="eyebrow">Daily Review</p>
        <h2 id="review-actions-title">Close one block at a time</h2>
      </div>

      <DailyReviewCards
        blocks={appState.executionBlocks.map((block) => ({
          id: block.id,
          title: block.title,
          tasks: (appState.tasksByBlockId[block.id] ?? []).map((task) => ({
            id: task.id,
            title: task.title,
            status: task.status,
          })),
        }))}
      />
    </section>

    <section class="islands review-islands" aria-label="Chronos review content">
      {
        appState.conclusionPanel ? (
          <ConclusionPanel {...appState.conclusionPanel} client:load />
        ) : (
          <section class="empty-panel">
            <h2>No conclusion review yet</h2>
            <p>Conclude an execution block to see its notes, timing, and next adjustment here.</p>
          </section>
        )
      }
    </section>
  </div>
</ChronosAppShell>

<style>
  .app-route--review {
    --app-route-max: 86rem;
  }

  @media (min-width: 100rem) {
    .app-route--review {
      --app-route-max: 100rem;
    }

    .app-route--review .action-card--wide {
      padding: clamp(1.15rem, 1.4vw, 1.45rem);
    }
  }

  @media (min-width: 120rem) {
    .app-route--review {
      --app-route-max: 104rem;
    }
  }
</style>
