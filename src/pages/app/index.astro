---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { ChronosAuthLocals } from '../../server/auth';

const locals = Astro.locals as ChronosAuthLocals;
const email = locals.user?.email ?? 'Signed-in user';
---

<BaseLayout title="Chronos App Shell">
  <main class="shell">
    <section class="panel" aria-labelledby="app-title">
      <p class="eyebrow">Protected app shell</p>
      <h1 id="app-title">Chronos is ready for your planning surfaces.</h1>
      <p class="summary">
        You are signed in as <strong>{email}</strong>. This protected shell establishes the session
        boundary for the timeline, calendar, task, review, and metrics surfaces that will be added
        in later slices.
      </p>

      <form method="post" action="/sign-out">
        <button type="submit">Sign out</button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>
  .shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 52%, #0f766e 100%);
  }

  .panel {
    width: min(100%, 44rem);
    padding: clamp(2rem, 5vw, 3.5rem);
    border: 1px solid rgba(204, 251, 241, 0.28);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.82);
    box-shadow: 0 24px 80px rgba(2, 6, 23, 0.34);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #5eead4;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .summary {
    margin: 1.5rem 0 2rem;
    color: #cbd5e1;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    background: #ccfbf1;
    color: #134e4a;
    cursor: pointer;
    font-weight: 700;
  }
</style>
