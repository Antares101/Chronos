---
import BlockDetail from '../../components/block/BlockDetail';
import ConclusionPanel from '../../components/review/ConclusionPanel';
import TaskList from '../../components/tasks/TaskList';
import WeeklyInsight from '../../components/metrics/WeeklyInsight';
import WeeklyCalendar from '../../components/calendar/WeeklyCalendar';
import DailyTimeline from '../../components/timeline/DailyTimeline';
import { blockCategories } from '../../domain/models';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { ChronosAuthLocals } from '../../server/auth';
import {
  categoryLabels,
  getChronosAppStatusMessage,
  getDateInputValue,
  getTimeInputValue,
  handleChronosAppAction,
  loadChronosAppState,
} from '../../server/app/chronos-app';
import { createChronosAppRepositories } from '../../server/app/repositories';

const locals = Astro.locals as ChronosAuthLocals;
const user = locals.user;

if (!user) {
  return Astro.redirect('/sign-in?redirectTo=/app');
}

const repositories = createChronosAppRepositories();
let actionError: string | null = null;

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const result = await handleChronosAppAction(repositories, user.id, formData);
    const nextUrl = new URL('/app', Astro.url);

    nextUrl.searchParams.set('status', result.status);

    return Astro.redirect(`${nextUrl.pathname}${nextUrl.search}`, 303);
  } catch (error) {
    actionError = error instanceof Error ? error.message : 'The Chronos action could not be saved.';
  }
}

const appState = await loadChronosAppState(repositories, user.id);
const email = user.email ?? 'Signed-in user';
const statusMessage = actionError
  ? null
  : getChronosAppStatusMessage(Astro.url.searchParams.get('status'));
const firstPlanningBlock = appState.planningBlocks[0] ?? null;
const defaultCreateDate = appState.defaultPlanningDate;
const defaultEditDate = firstPlanningBlock
  ? getDateInputValue(firstPlanningBlock.plannedStart)
  : defaultCreateDate;
const defaultEditStartTime = firstPlanningBlock
  ? getTimeInputValue(firstPlanningBlock.plannedStart)
  : '09:00';
const defaultEditEndTime = firstPlanningBlock
  ? getTimeInputValue(firstPlanningBlock.plannedEnd)
  : '10:00';

function getBlockTasks(blockId: string) {
  return appState.tasksByBlockId[blockId] ?? [];
}
---

<BaseLayout title="Chronos App Shell">
  <main class="shell">
    <section class="hero" aria-labelledby="app-title">
      <div>
        <p class="eyebrow">Protected app shell</p>
        <h1 id="app-title">Chronos planning surfaces</h1>
        <p class="summary">
          You are signed in as <strong>{email}</strong>. Blocks, tasks, pauses, reviews, and metrics
          are loaded from your authenticated backend scope.
        </p>
      </div>

      <form method="post" action="/sign-out">
        <button type="submit">Sign out</button>
      </form>
    </section>

    {
      actionError && (
        <p class="alert" role="alert">
          {actionError}
        </p>
      )
    }
    {statusMessage && <p class="notice">{statusMessage}</p>}

    <section class="actions" aria-labelledby="actions-title">
      <div class="actions__header">
        <p class="eyebrow">Backend actions</p>
        <h2 id="actions-title">Plan, move, pause, and conclude persisted blocks</h2>
      </div>

      <div class="actions__grid">
        <article class="action-card">
          <h3>Create planned block</h3>
          <form method="post">
            <input type="hidden" name="action" value="create-planned-block" />
            <label>
              Title
              <input name="title" required maxlength="120" placeholder="Deep work" />
            </label>
            <label>
              Category
              <select name="category" required>
                {
                  blockCategories.map((category) => (
                    <option value={category}>{categoryLabels[category]}</option>
                  ))
                }
              </select>
            </label>
            <div class="form-row">
              <label>
                Day
                <input type="date" name="date" value={defaultCreateDate} required />
              </label>
              <label>
                Start
                <input type="time" name="startTime" value="09:00" required />
              </label>
              <label>
                End
                <input type="time" name="endTime" value="10:00" required />
              </label>
            </div>
            <button type="submit">Create planned block</button>
          </form>
        </article>

        <article class="action-card">
          <h3>Edit planned schedule</h3>
          <form method="post">
            <input type="hidden" name="action" value="update-planned-schedule" />
            <label>
              Planning block
              <select name="blockId" required disabled={appState.planningBlocks.length === 0}>
                {
                  appState.planningBlocks.map((block) => (
                    <option value={block.id}>
                      {block.title} · {getDateInputValue(block.plannedStart)}
                    </option>
                  ))
                }
              </select>
            </label>
            <div class="form-row">
              <label>
                New day
                <input type="date" name="date" value={defaultEditDate} required />
              </label>
              <label>
                Start
                <input type="time" name="startTime" value={defaultEditStartTime} required />
              </label>
              <label>
                End
                <input type="time" name="endTime" value={defaultEditEndTime} required />
              </label>
            </div>
            <button type="submit" disabled={appState.planningBlocks.length === 0}>
              Update planned schedule
            </button>
          </form>
        </article>

        <article class="action-card">
          <h3>Move task into block</h3>
          <form method="post">
            <input type="hidden" name="action" value="assign-task" />
            <label>
              Unassigned task
              <select name="taskId" required disabled={appState.assignableTasks.length === 0}>
                {
                  appState.assignableTasks.map((task) => (
                    <option value={task.id}>{task.title}</option>
                  ))
                }
              </select>
            </label>
            <label>
              Target block
              <select name="blockId" required disabled={appState.blocks.length === 0}>
                {
                  appState.blocks.map((block) => (
                    <option value={block.id}>
                      {block.title} · {block.phase}
                    </option>
                  ))
                }
              </select>
            </label>
            <button
              type="submit"
              disabled={appState.assignableTasks.length === 0 || appState.blocks.length === 0}
            >
              Move task
            </button>
          </form>
        </article>

        <article class="action-card">
          <h3>Create task inside block</h3>
          <form method="post">
            <input type="hidden" name="action" value="create-task" />
            <label>
              Target block
              <select name="blockId" required disabled={appState.blocks.length === 0}>
                {
                  appState.blocks.map((block) => (
                    <option value={block.id}>
                      {block.title} · {block.phase}
                    </option>
                  ))
                }
              </select>
            </label>
            <label>
              Task title
              <input name="title" required maxlength="120" placeholder="Prepare notes" />
            </label>
            <button type="submit" disabled={appState.blocks.length === 0}> Create task </button>
          </form>
        </article>

        <article class="action-card">
          <h3>Add highlighted event</h3>
          <form method="post">
            <input type="hidden" name="action" value="create-highlighted-event" />
            <label>
              Target block
              <select name="blockId" required disabled={appState.blocks.length === 0}>
                {
                  appState.blocks.map((block) => (
                    <option value={block.id}>
                      {block.title} · {block.phase}
                    </option>
                  ))
                }
              </select>
            </label>
            <label>
              Event title
              <input name="title" required maxlength="120" placeholder="Important handoff" />
            </label>
            <button type="submit" disabled={appState.blocks.length === 0}>
              Add highlighted event
            </button>
          </form>
        </article>

        <article class="action-card">
          <h3>Start planned block</h3>
          <form method="post">
            <input type="hidden" name="action" value="start-block" />
            <label>
              Planning block
              <select name="blockId" required disabled={appState.planningBlocks.length === 0}>
                {
                  appState.planningBlocks.map((block) => (
                    <option value={block.id}>{block.title}</option>
                  ))
                }
              </select>
            </label>
            <button type="submit" disabled={appState.planningBlocks.length === 0}>
              Start block
            </button>
          </form>
        </article>

        <article class="action-card action-card--wide">
          <h3>Conclude execution block</h3>
          {
            appState.executionBlocks.length === 0 ? (
              <p class="empty-copy">No execution blocks are ready to conclude.</p>
            ) : (
              appState.executionBlocks.map((block) => (
                <form method="post" class="conclusion-form">
                  <input type="hidden" name="action" value="conclude-block" />
                  <input type="hidden" name="blockId" value={block.id} />
                  <p class="form-heading">{block.title}</p>
                  <fieldset>
                    <legend>Completed tasks</legend>
                    {getBlockTasks(block.id).length === 0 ? (
                      <p class="empty-copy">No tasks are attached to this block.</p>
                    ) : (
                      getBlockTasks(block.id).map((task) => (
                        <label class="checkbox-label">
                          <input
                            type="checkbox"
                            name="completedTaskIds"
                            value={task.id}
                            checked={task.status === 'done'}
                          />
                          {task.title}
                        </label>
                      ))
                    )}
                  </fieldset>
                  <label>
                    Notes
                    <textarea name="notes" required rows="3" placeholder="What happened?" />
                  </label>
                  <label>
                    Next adjustment
                    <input name="nextAdjustment" placeholder="Optional follow-up" />
                  </label>
                  <button type="submit">Save conclusion</button>
                </form>
              ))
            )
          }
        </article>
      </div>
    </section>

    <section class="islands" aria-label="Chronos daily and weekly planning surfaces">
      <DailyTimeline {...appState.dailyTimeline} client:load />
      <WeeklyCalendar {...appState.weeklyCalendar} client:load />
      <TaskList {...appState.taskList} client:load />
      {
        appState.blockDetail ? (
          <BlockDetail {...appState.blockDetail} pauseActionPath="/app" client:load />
        ) : (
          <section class="empty-panel">
            <h2>No block selected yet</h2>
            <p>Create a planned block to populate the block context and pause controls.</p>
          </section>
        )
      }
      {
        appState.conclusionPanel ? (
          <ConclusionPanel {...appState.conclusionPanel} client:load />
        ) : (
          <section class="empty-panel">
            <h2>No conclusion review yet</h2>
            <p>Conclude an execution block to show its persisted review.</p>
          </section>
        )
      }
      <WeeklyInsight {...appState.weeklyInsight} client:load />
    </section>
  </main>
</BaseLayout>

<style>
  .shell {
    min-height: 100vh;
    padding: clamp(1rem, 2vw, 2rem);
    background:
      radial-gradient(circle at top left, rgba(94, 234, 212, 0.22), transparent 30rem),
      linear-gradient(135deg, #0f172a 0%, #1e293b 52%, #0f766e 100%);
  }

  .hero {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    width: min(100%, 86rem);
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid rgba(204, 251, 241, 0.28);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.82);
    box-shadow: 0 24px 80px rgba(2, 6, 23, 0.34);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #5eead4;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .summary {
    max-width: 58rem;
    margin: 1rem 0 0;
    color: #cbd5e1;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .notice,
  .alert,
  .actions,
  .empty-panel {
    width: min(100%, 86rem);
    margin: 1rem auto 0;
  }

  .notice,
  .alert {
    border-radius: 1rem;
    padding: 0.85rem 1rem;
    font-weight: 700;
  }

  .notice {
    background: rgba(187, 247, 208, 0.16);
    color: #bbf7d0;
  }

  .alert {
    background: rgba(254, 202, 202, 0.16);
    color: #fecaca;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    background: #ccfbf1;
    color: #134e4a;
    cursor: pointer;
    font-weight: 700;
  }

  button:disabled {
    background: #94a3b8;
    color: #475569;
    cursor: not-allowed;
  }

  .actions {
    border: 1px solid rgba(204, 251, 241, 0.28);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.82);
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .actions__header h2,
  .action-card h3,
  .empty-panel h2 {
    margin: 0;
  }

  .actions__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .action-card,
  .empty-panel {
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 1.2rem;
    background: rgba(248, 250, 252, 0.96);
    color: #0f172a;
    padding: 1rem;
  }

  .action-card--wide {
    grid-column: 1 / -1;
  }

  .action-card form,
  .action-card label {
    display: grid;
    gap: 0.45rem;
  }

  .action-card form {
    margin-top: 0.85rem;
    gap: 0.75rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgba(15, 118, 110, 0.32);
    border-radius: 0.75rem;
    padding: 0.7rem 0.8rem;
    background: #ffffff;
    color: #0f172a;
    font: inherit;
  }

  fieldset {
    display: grid;
    gap: 0.45rem;
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 0.9rem;
    padding: 0.75rem;
  }

  legend,
  .form-heading,
  .action-card label {
    font-weight: 800;
  }

  .checkbox-label {
    display: flex;
    grid-template-columns: none;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
  }

  .checkbox-label input {
    width: auto;
  }

  .conclusion-form + .conclusion-form {
    border-top: 1px solid rgba(148, 163, 184, 0.3);
    padding-top: 0.85rem;
  }

  .empty-copy,
  .empty-panel p {
    color: #475569;
    font-weight: 700;
  }

  .islands {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    width: min(100%, 86rem);
    margin: 1rem auto 0;
  }

  @media (max-width: 760px) {
    .hero {
      align-items: flex-start;
      flex-direction: column;
    }

    .actions__grid,
    .form-row {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
