---

<BaseLayout title="Chronos App Shell">
  <main class="shell">
    <section class="hero" aria-labelledby="app-title">
      <div>
        <p class="eyebrow">Protected app shell</p>
        <h1 id="app-title">Chronos planning surfaces</h1>
        <p class="summary">
          You are signed in as <strong>{email}</strong>. These Slice 3B islands use local sample
          data only while the protected session boundary remains in place.
        </p>
      </div>

      <form method="post" action="/sign-out">
        <button type="submit">Sign out</button>
      </form>
    </section>

    <section class="islands" aria-label="Chronos daily and weekly planning surfaces">
      <DailyTimeline {...dailyTimelineSample} client:load />
      <WeeklyCalendar {...weeklyCalendarSample} client:load />
    </section>
  </main>
</BaseLayout>

<style>
  .shell {
    min-height: 100vh;
    padding: clamp(1rem, 2vw, 2rem);
    background:
      radial-gradient(circle at top left, rgba(94, 234, 212, 0.22), transparent 30rem),
      linear-gradient(135deg, #0f172a 0%, #1e293b 52%, #0f766e 100%);
  }

  .hero {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    width: min(100%, 86rem);
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid rgba(204, 251, 241, 0.28);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.82);
    box-shadow: 0 24px 80px rgba(2, 6, 23, 0.34);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #5eead4;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .summary {
    max-width: 58rem;
    margin: 1rem 0 0;
    color: #cbd5e1;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    background: #ccfbf1;
    color: #134e4a;
    cursor: pointer;
    font-weight: 700;
  }

  .islands {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
    width: min(100%, 86rem);
    margin: 1rem auto 0;
  }

  @media (max-width: 760px) {
    .hero {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
