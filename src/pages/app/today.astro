---
import BlockDetail from '../../components/block/BlockDetail';
import ChronosAppShell from '../../components/app/ChronosAppShell.astro';
import DailyTimeline from '../../components/timeline/DailyTimeline';
import TodayGoalsPanel from '../../components/today/TodayGoalsPanel';
import TodayOperatingSummary from '../../components/today/TodayOperatingSummary';
import QuickTaskCapture from '../../components/today/QuickTaskCapture';
import TodayActionsGrid from '../../components/today/TodayActionsGrid';
import TodayTaskPanel from '../../components/today/TodayTaskPanel';
import { buildQuickSchedulePreview } from '../../components/today/quick-schedule-selector';
import type { ChronosAuthLocals } from '../../server/auth';
import { loadChronosTodayState } from '../../server/app/chronos-app';
import {
  chronosAppRoutes,
  resolveChronosActionRouteContext,
} from '../../server/app/route-contract';

const routePath = chronosAppRoutes.today;

const routeContext = await resolveChronosActionRouteContext({
  user: (Astro.locals as ChronosAuthLocals).user,
  request: Astro.request,
  currentUrl: Astro.url,
  routePath,
});

if (routeContext.kind === 'redirect') {
  return Astro.redirect(routeContext.location, routeContext.status);
}

const { actionError, email, repositories, statusMessage, userId } = routeContext;
const appState = await loadChronosTodayState(repositories, userId);
const quickBlockPreview = buildQuickSchedulePreview({
  date: appState.quickBlockDefaults.date,
  todayDate: appState.todayDate,
  startTime: appState.quickBlockDefaults.startTime,
  endTime: appState.quickBlockDefaults.endTime,
});
---

<ChronosAppShell
  title="Chronos Today"
  eyebrow="CHRONOS"
  heading="Run the day"
  summary="Run today from now, timeline, tasks, and blocks."
  email={email}
  currentPath={routePath}
  actionError={actionError}
  statusMessage={statusMessage}
>
  <div class="app-route app-route--today">
    <div class="today-summary-block">
      <TodayOperatingSummary {...appState.todayOperatingSummary} />
    </div>

    <section class="islands today-workspace" aria-label="Chronos today workspace">
      <div class="today-workspace__timeline">
        <DailyTimeline {...appState.dailyTimeline} client:load />
        {
          appState.blockDetail ? (
            <BlockDetail
              {...appState.blockDetail}
              pauseActionPath={routePath}
              taskActionPath={routePath}
              client:load
            />
          ) : (
            <section class="empty-panel">
              <h2>No block selected yet</h2>
              <p>
                Create or start a planning block to see its tasks, events, and pause controls here.
              </p>
            </section>
          )
        }
      </div>

      <aside class="today-workspace__utility" aria-label="Today controls and lists">
        <section class="actions" aria-labelledby="today-actions-title">
          <div class="actions__header">
            <p class="eyebrow">Today controls</p>
            <h2 id="today-actions-title">Start, shape, and capture work</h2>
          </div>

          <QuickTaskCapture
            blocks={appState.blocks.map(({ id, title, phase }) => ({ id, title, phase }))}
            currentBlockId={appState.todayTaskPanel.currentBlockId}
            currentBlockTitle={appState.todayTaskPanel.currentBlockTitle}
          />

          <TodayActionsGrid
            planningBlocks={appState.planningBlocks}
            blocks={appState.blocks.map(({ id, title, phase }) => ({ id, title, phase }))}
            todayDate={appState.todayDate}
            quickBlockDefaults={appState.quickBlockDefaults}
            quickBlockPreview={quickBlockPreview}
          />
        </section>

        <div class="today-grid" aria-label="Today tasks and goals">
          <TodayTaskPanel {...appState.todayTaskPanel} actionPath={routePath} />
          <TodayGoalsPanel
            title="Goals for today"
            description="Pick up to three outcomes for today."
            goals={appState.todayGoals}
            maxGoals={3}
            actionPath={routePath}
          />
        </div>
      </aside>
    </section>
  </div>
</ChronosAppShell>

<script>
  import { bindQuickScheduleSelectors } from '../../components/today/quick-schedule-selector';

  const bindQuickSchedule = () => bindQuickScheduleSelectors(document);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindQuickSchedule, { once: true });
  } else {
    bindQuickSchedule();
  }
</script>

<style>
  .app-route--today {
    --today-chrome-max: 96rem;
    --today-workspace-max: 96rem;
    --app-route-max: var(--today-workspace-max);
  }

  :global(.shell:has(.app-route--today)) {
    --today-chrome-max: 96rem;
  }

  :global(.shell:has(.app-route--today) .command-bar) {
    width: min(100%, var(--today-chrome-max));
  }

  .today-summary-block {
    width: min(100%, var(--today-chrome-max));
    max-width: var(--today-chrome-max);
    margin: 0.85rem auto 0;
    min-width: 0;
  }

  .today-summary-block :global(.today-operating-strip) {
    width: 100%;
    max-width: 100%;
  }

  .today-workspace {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
    gap: clamp(0.85rem, 1.4vw, 1.15rem);
    margin-top: 0.85rem;
    min-width: 0;
  }

  .today-workspace,
  .today-workspace__timeline,
  .today-workspace__utility,
  .today-grid {
    min-width: 0;
  }

  .today-workspace__timeline,
  .today-workspace__utility {
    display: grid;
    gap: clamp(0.85rem, 1.4vw, 1.15rem);
  }

  .today-workspace__utility .actions {
    width: 100%;
    margin: 0;
    padding: clamp(0.9rem, 1.5vw, 1.15rem);
  }

  .today-workspace__utility .actions__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 0.85rem;
    max-width: none;
  }

  .today-workspace__utility .actions__header h2 {
    font-size: clamp(1.15rem, 1.5vw, 1.45rem);
  }

  .today-workspace__utility :global(.quick-task-capture) {
    margin-top: 0.8rem;
  }

  .today-workspace__utility :global(.quick-task-capture__form) {
    grid-template-columns: minmax(0, 1fr);
  }

  .today-workspace__utility :global(.actions__grid) {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
    gap: 0.8rem;
    margin-top: 0.8rem;
  }

  .today-workspace__utility :global(.action-card) {
    padding: clamp(0.85rem, 1.2vw, 1rem);
  }

  .today-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: clamp(0.85rem, 1.4vw, 1rem);
  }

  @media (min-width: 88rem) {
    .today-workspace {
      grid-template-columns: minmax(0, 1.45fr) minmax(24rem, 0.8fr);
    }

    .today-workspace__timeline {
      grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.75fr);
    }

    .today-workspace__timeline :global(.block-detail__task) {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    .today-workspace__timeline :global(.block-detail__task > span:first-child) {
      grid-column: 1 / -1;
      overflow-wrap: break-word;
      word-break: normal;
    }

    .today-workspace__timeline :global(.block-detail__task form) {
      justify-self: end;
    }

    .today-workspace__timeline > *,
    .today-workspace__utility > * {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .today-workspace__utility {
      position: sticky;
      top: clamp(0.75rem, 1.5vw, 1.25rem);
      align-self: start;
    }
  }

  @media (min-width: 100rem) {
    .app-route--today {
      --today-workspace-max: 120rem;
    }

    .today-workspace {
      grid-template-columns: minmax(0, 1.55fr) minmax(30rem, 0.85fr);
    }
  }

  @media (min-width: 120rem) {
    .app-route--today {
      --today-workspace-max: 152rem;
    }

    .today-workspace {
      grid-template-columns: minmax(0, 1.65fr) minmax(36rem, 0.9fr);
    }
  }

  @media (min-width: 150rem) {
    .app-route--today {
      --today-workspace-max: 176rem;
    }

    .today-workspace {
      grid-template-columns: minmax(0, 1.75fr) minmax(40rem, 0.85fr);
    }
  }

  @media (max-width: 54rem) {
    .today-workspace__utility .actions__header {
      display: grid;
    }
  }
</style>
