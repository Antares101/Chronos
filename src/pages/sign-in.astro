---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRedirectTarget, resolveSignInPostDecision } from '../server/auth';
import type { ChronosAuthLocals } from '../server/auth';

let message: string | null = null;
let errorMessage: string | null = Astro.url.searchParams.has('error')
  ? 'The sign-in link could not be confirmed. Please request a new link.'
  : null;
const redirectTo = getRedirectTarget(Astro.url);
const locals = Astro.locals as ChronosAuthLocals;

if (locals.user) {
  return Astro.redirect(redirectTo);
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const decision = await resolveSignInPostDecision(
    Astro.url,
    formData,
    locals.supabase.auth.signInWithOtp.bind(locals.supabase.auth),
  );

  errorMessage = decision.errorMessage;
  message = decision.message;
}
---

<BaseLayout title="Sign in to Chronos">
  <main class="shell">
    <section class="panel" aria-labelledby="sign-in-title">
      <p class="eyebrow">Chronos</p>
      <h1 id="sign-in-title">Sign in to open Chronos.</h1>
      <p class="summary">
        Enter my email and use the sign-in link to get back to my planning space.
      </p>

      {
        errorMessage && (
          <p class="alert" role="alert">
            {errorMessage}
          </p>
        )
      }
      {message && <p class="notice">{message}</p>}

      <form method="post">
        <input type="hidden" name="redirectTo" value={redirectTo} />
        <label>
          Email
          <input type="email" name="email" autocomplete="email" required />
        </label>
        <button type="submit">Send sign-in link</button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>
  .shell {
    --sign-in-bg: var(--chronos-inverse-surface, #020617);
    --sign-in-bg-soft: var(--chronos-inverse-surface-muted, #111827);
    --sign-in-bg-accent: var(--chronos-inverse-surface-accent, #312e81);
    --sign-in-panel: var(--chronos-inverse-surface-elevated, rgba(15, 23, 42, 0.84));
    --sign-in-text: var(--chronos-inverse-text, #f8fafc);
    --sign-in-text-muted: var(--chronos-inverse-text-muted, #cbd5e1);
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background: linear-gradient(
      135deg,
      var(--sign-in-bg) 0%,
      var(--sign-in-bg-soft) 54%,
      var(--sign-in-bg-accent) 100%
    );
  }

  .panel {
    width: min(100%, 32rem);
    padding: clamp(2rem, 5vw, 3rem);
    border: 1px solid rgba(165, 180, 252, 0.32);
    border-radius: 1.5rem;
    background: var(--sign-in-panel);
    color: var(--sign-in-text);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--chronos-inverse-primary-text, #a5b4fc);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.25rem, 8vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .summary,
  .notice,
  .alert {
    line-height: 1.6;
  }

  .summary {
    color: var(--sign-in-text-muted);
  }

  .notice {
    color: var(--chronos-inverse-success-text, #bbf7d0);
  }

  .alert {
    color: var(--chronos-inverse-danger-text, #fecaca);
  }

  form,
  label {
    display: grid;
    gap: 0.75rem;
  }

  form {
    margin-top: 1.5rem;
  }

  input {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    min-height: 44px;
    border: 1px solid rgba(148, 163, 184, 0.42);
    border-radius: 0.75rem;
    padding: 0.8rem 0.9rem;
    background: var(--sign-in-bg);
    color: var(--sign-in-text);
  }

  input:focus-visible {
    border-color: var(--chronos-inverse-primary-text, #a5b4fc);
    outline: none;
    box-shadow: 0 0 0 3px rgba(165, 180, 252, 0.34);
  }

  button {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    min-height: 44px;
    border: 1px solid var(--chronos-border-strong, rgba(99, 102, 241, 0.22));
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    background: var(--chronos-primary-soft, #c7d2fe);
    color: var(--chronos-primary-strong, #312e81);
    cursor: pointer;
    font-weight: 700;
  }

  button:focus-visible {
    border-color: var(--chronos-inverse-primary-text, #a5b4fc);
    outline: none;
    box-shadow: 0 0 0 3px rgba(165, 180, 252, 0.34);
  }
</style>
