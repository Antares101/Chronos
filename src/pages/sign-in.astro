---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRedirectTarget, resolveSignInPostDecision } from '../server/auth';
import type { ChronosAuthLocals } from '../server/auth';

let message: string | null = null;
let errorMessage: string | null = Astro.url.searchParams.has('error')
  ? 'The sign-in link could not be confirmed. Please request a new link.'
  : null;
const redirectTo = getRedirectTarget(Astro.url);
const locals = Astro.locals as ChronosAuthLocals;

if (locals.user) {
  return Astro.redirect(redirectTo);
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const decision = await resolveSignInPostDecision(
    Astro.url,
    formData,
    locals.supabase.auth.signInWithOtp.bind(locals.supabase.auth),
  );

  errorMessage = decision.errorMessage;
  message = decision.message;
}
---

<BaseLayout title="Sign in to Chronos">
  <main class="shell">
    <section class="panel" aria-labelledby="sign-in-title">
      <p class="eyebrow">Chronos</p>
      <h1 id="sign-in-title">Sign in to continue.</h1>
      <p class="summary">Use a Supabase magic link to access the protected Chronos app shell.</p>

      {
        errorMessage && (
          <p class="alert" role="alert">
            {errorMessage}
          </p>
        )
      }
      {message && <p class="notice">{message}</p>}

      <form method="post">
        <input type="hidden" name="redirectTo" value={redirectTo} />
        <label>
          Email
          <input type="email" name="email" autocomplete="email" required />
        </label>
        <button type="submit">Send sign-in link</button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>
  .shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background: linear-gradient(135deg, #020617 0%, #111827 54%, #312e81 100%);
  }

  .panel {
    width: min(100%, 32rem);
    padding: clamp(2rem, 5vw, 3rem);
    border: 1px solid rgba(165, 180, 252, 0.32);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.84);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #a5b4fc;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.25rem, 8vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .summary,
  .notice,
  .alert {
    line-height: 1.6;
  }

  .summary {
    color: #cbd5e1;
  }

  .notice {
    color: #bbf7d0;
  }

  .alert {
    color: #fecaca;
  }

  form,
  label {
    display: grid;
    gap: 0.75rem;
  }

  form {
    margin-top: 1.5rem;
  }

  input {
    border: 1px solid rgba(148, 163, 184, 0.42);
    border-radius: 0.75rem;
    padding: 0.8rem 0.9rem;
    background: #020617;
    color: #f8fafc;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    background: #c7d2fe;
    color: #312e81;
    cursor: pointer;
    font-weight: 700;
  }
</style>
