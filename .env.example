# Public Supabase browser/client contract.
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional public origin used to build Supabase auth callback URLs in deployed environments.
PUBLIC_AUTH_REDIRECT_ORIGIN="http://localhost:4321"

# Server-only database contract for Drizzle Kit and future server adapters.
DATABASE_URL="postgresql://db-host:5432/db-name"
